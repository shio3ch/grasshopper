---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="ホーム" description="grasshopper - tech news blog">
  <section>
    <h1 style="font-size:1.75rem;font-weight:700;margin-bottom:0.5rem;">
      技術ニュース
    </h1>
    <p style="color:#555;margin-bottom:2rem;">
      最新の技術トレンドやニュースをお届けします。
    </p>

    {
      posts.length === 0 ? (
        <p style="color:#888;">記事がありません。</p>
      ) : (
        posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.slug}
          />
        ))
      )
    }
  </section>
</BaseLayout>
