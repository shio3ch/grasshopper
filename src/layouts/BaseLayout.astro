---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "grasshopper - tech news blog" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | grasshopper</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          "Helvetica Neue", Arial, sans-serif;
        line-height: 1.6;
        color: #1a1a1a;
        background: #f9f9f9;
      }

      a {
        color: #0070f3;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      main {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }
    </style>
  </head>
  <body>
    <header
      style="background:#fff;border-bottom:1px solid #eaeaea;padding:1rem;"
    >
      <div
        style="max-width:800px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;"
      >
        <a href="/" style="font-size:1.4rem;font-weight:700;color:#1a1a1a;"
          >🦗 grasshopper</a
        >
        <nav>
          <a href="/" style="margin-left:1.5rem;color:#555;">ホーム</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer
      style="text-align:center;padding:2rem 1rem;color:#888;font-size:0.875rem;border-top:1px solid #eaeaea;margin-top:4rem;"
    >
      <p>&copy; {new Date().getFullYear()} grasshopper. All rights reserved.</p>
    </footer>
  </body>
</html>
