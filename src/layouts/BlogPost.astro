---
import BaseLayout from "./BaseLayout.astro";
import { formatDate, toISODateString } from "../utils/formatDate";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  author?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  author = "grasshopper",
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article>
    <header style="margin-bottom:2rem;">
      <h1
        style="font-size:2rem;font-weight:700;line-height:1.3;margin-bottom:0.75rem;"
      >
        {title}
      </h1>
      <p style="color:#555;font-size:0.95rem;margin-bottom:0.5rem;">
        <time datetime={toISODateString(pubDate)}>{formatDate(pubDate)}</time>
        {
          updatedDate && (
            <span style="margin-left:1rem;">
              更新:{" "}
              <time datetime={toISODateString(updatedDate)}>
                {formatDate(updatedDate)}
              </time>
            </span>
          )
        }
        <span style="margin-left:1rem;">by {author}</span>
      </p>
      {
        tags.length > 0 && (
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
            {tags.map((tag) => (
              <span style="background:#eef2ff;color:#3730a3;padding:0.2rem 0.6rem;border-radius:9999px;font-size:0.8rem;">
                #{tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <div class="prose" style="line-height:1.8;">
      <slot />
    </div>

    <div
      style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid #eaeaea;"
    >
      <a href="/" style="color:#0070f3;">&larr; 記事一覧に戻る</a>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2rem 0 1rem;
  }

  .prose h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 1.5rem 0 0.75rem;
  }

  .prose p {
    margin-bottom: 1rem;
  }

  .prose ul,
  .prose ol {
    margin: 1rem 0 1rem 1.5rem;
  }

  .prose li {
    margin-bottom: 0.25rem;
  }

  .prose pre {
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1rem 0;
    font-size: 0.9rem;
  }

  .prose code:not(pre code) {
    background: #f0f0f0;
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .prose a {
    color: #0070f3;
  }

  .prose strong {
    font-weight: 700;
  }
</style>
